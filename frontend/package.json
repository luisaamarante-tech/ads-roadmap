{
  "name": "vtex-ads-roadmap-frontend",
  "version": "1.0.0",
  "description": "Public roadmap for VTEX Ads",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{vue,ts,js,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,css}\"",
    "stylelint": "stylelint \"src/**/*.{vue,css}\" --fix",
    "stylelint:check": "stylelint \"src/**/*.{vue,css}\"",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@weni/unnnic-system": "^3.25.3",
    "axios": "^1.6.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.24.0",
    "jsdom": "^24.0.0",
    "postcss-html": "^1.6.0",
    "prettier": "^3.7.4",
    "stylelint": "^16.3.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-selector-bem-pattern": "^4.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.2.12"
  }
}
