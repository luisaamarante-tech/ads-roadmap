# Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# API Configuration
# Local development: point to the Flask backend
# Vercel production: use /api (same domain, no CORS needed)
VITE_API_BASE_URL=http://localhost:5000

# Application Configuration (OPTIONAL)
VITE_APP_NAME=VTEX Ads Roadmap
VITE_APP_VERSION=1.0.0

# Build Configuration (OPTIONAL)
NODE_ENV=development

# Auth Protection (simple username/password login gate)
# Set these in Vercel Settings → Environment Variables
VITE_AUTH_USERNAME=vtexads
VITE_AUTH_PASSWORD=change-me

# IMPORTANT: All VITE_* variables are embedded in frontend bundle (PUBLIC)
# These credentials provide lightweight access control, not cryptographic security
