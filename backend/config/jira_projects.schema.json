{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vtexads.com/schemas/jira-projects-config.json",
  "title": "JIRA Projects Custom Field Configuration",
  "description": "Configuration file mapping JIRA project keys to their custom field IDs for roadmap data extraction",
  "type": "object",
  "required": ["version", "projects"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Configuration format version (semantic versioning: major.minor)",
      "examples": ["1.0", "2.0"]
    },
    "projects": {
      "type": "object",
      "description": "Map of JIRA project keys to their custom field configurations",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Z][A-Z0-9]{1,9}$": {
          "type": "object",
          "description": "Custom field mapping for a single JIRA project",
          "required": [
            "public_roadmap",
            "roadmap_status",
            "module",
            "release_year",
            "release_quarter",
            "release_month",
            "documentation_url",
            "roadmap_title",
            "roadmap_description",
            "roadmap_image_url_1",
            "roadmap_image_url_2",
            "roadmap_image_url_3",
            "roadmap_image_url_4",
            "roadmap_likes"
          ],
          "properties": {
            "public_roadmap": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Field to mark epic as public for roadmap",
              "examples": ["customfield_10001"]
            },
            "roadmap_status": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Delivery status (DELIVERED, NOW, NEXT, FUTURE)",
              "examples": ["customfield_10002"]
            },
            "module": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Product module/area",
              "examples": ["customfield_10003"]
            },
            "release_year": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Release year",
              "examples": ["customfield_10004"]
            },
            "release_quarter": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Release quarter (Q1, Q2, Q3, Q4)",
              "examples": ["customfield_10005"]
            },
            "release_month": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Release month (1-12)",
              "examples": ["customfield_10006"]
            },
            "documentation_url": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Documentation URL",
              "examples": ["customfield_10007"]
            },
            "roadmap_title": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for public roadmap title",
              "examples": ["customfield_10101"]
            },
            "roadmap_description": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for public roadmap description",
              "examples": ["customfield_10102"]
            },
            "roadmap_image_url_1": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for first image URL",
              "examples": ["customfield_10103"]
            },
            "roadmap_image_url_2": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for second image URL",
              "examples": ["customfield_10104"]
            },
            "roadmap_image_url_3": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for third image URL",
              "examples": ["customfield_10105"]
            },
            "roadmap_image_url_4": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for fourth image URL",
              "examples": ["customfield_10106"]
            },
            "roadmap_likes": {
              "type": "string",
              "pattern": "^customfield_\\d{5,}$",
              "description": "Custom field ID for storing the number of likes an epic has received",
              "examples": ["customfield_10107"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "version": "1.0",
      "projects": {
        "NEXUS": {
          "public_roadmap": "customfield_10001",
          "roadmap_status": "customfield_10002",
          "module": "customfield_10003",
          "release_year": "customfield_10004",
          "release_quarter": "customfield_10005",
          "release_month": "customfield_10006",
          "documentation_url": "customfield_10007",
          "roadmap_title": "customfield_10101",
          "roadmap_description": "customfield_10102",
          "roadmap_image_url_1": "customfield_10103",
          "roadmap_image_url_2": "customfield_10104",
          "roadmap_image_url_3": "customfield_10105",
          "roadmap_image_url_4": "customfield_10106",
          "roadmap_likes": "customfield_10107"
        }
      }
    }
  ]
}
